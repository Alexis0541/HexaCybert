---
import Logo from '~/components/Logo.astro';
import { contactEmail, contactMailto, getSection, legalPages, sectionOrder } from '~/data/hexacybert';
import type { Lang } from '~/utils/i18n';
import { languages, localizePath, ui } from '~/utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const year = 2026;
const legalLang = (['en', 'fr', 'es'].includes(lang) ? lang : 'en') as 'en' | 'fr' | 'es';
---

<footer class="border-t" style="border-color: var(--hc-border); background: var(--hc-bg)">
  <div class="hc-shell grid gap-10 py-12 md:grid-cols-[1.1fr_2fr]">
    <div>
      <Logo />
      <p class="mt-4 max-w-sm text-base leading-7 hc-muted">{t.footerDescription}</p>
      <p class="mt-4 text-sm hc-muted"><a class="hover:text-[var(--hc-accent)]" href={contactMailto}>{contactEmail}</a></p>
    </div>
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <h2 class="font-black">{t.categories}</h2>
        <ul class="mt-3 space-y-2 text-base hc-muted">
          {sectionOrder.slice(0, 9).map((key) => <li><a class="hover:text-[var(--hc-accent)]" href={localizePath(`/${key}`, lang)}>{getSection(lang, key).title}</a></li>)}
        </ul>
      </div>
      <div>
        <h2 class="font-black">{t.languages}</h2>
        <ul class="mt-3 space-y-2 text-base hc-muted">
          {Object.entries(languages).map(([code, label]) => <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/', code as Lang)}>{label}</a></li>)}
        </ul>
      </div>
      <div>
        <h2 class="font-black">{t.legal}</h2>
        <ul class="mt-3 space-y-2 text-base hc-muted">
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/privacy-policy', lang)}>{t.legalPrivacy}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/cookies', lang)}>{t.legalCookies}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/terms', lang)}>{t.legalTerms}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/legal-notice', lang)}>{legalPages['legal-notice'].title[legalLang]}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/affiliate-disclosure', lang)}>{legalPages['affiliate-disclosure'].title[legalLang]}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/editorial-policy', lang)}>{legalPages['editorial-policy'].title[legalLang]}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/corrections-policy', lang)}>{legalPages['corrections-policy'].title[legalLang]}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/methodology', lang)}>{legalPages.methodology.title[legalLang]}</a></li>
          <li><a class="hover:text-[var(--hc-accent)]" href={localizePath('/contact', lang)}>{t.navContact}</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="border-t px-4 py-5 text-center text-sm hc-muted" style="border-color: var(--hc-border)">
    Copyright {year} HexaCybert. {t.copyright}
  </div>
</footer>
