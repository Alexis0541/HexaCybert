---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import { getSection, sectionOrder } from '~/data/hexacybert';
import type { Lang } from '~/utils/i18n';
import { alternateLangPath, languages, localizePath, ui } from '~/utils/i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = ui[lang];
const labelFor = (key: string) => t[`nav${key.split('-').map((part) => part[0].toUpperCase() + part.slice(1)).join('')}` as keyof typeof t] ?? key;
const primary = ['guides', 'privacy-center', 'password-managers', 'comparisons', 'tools', 'news'];
const secondary = ['cybersecurity', 'device-security', 'wifi-security', 'resources'];
---

<header class="sticky top-0 z-50 border-b backdrop-blur" style="border-color: var(--hc-border); background: color-mix(in srgb, var(--hc-bg) 92%, transparent)">
  <div class="hc-shell flex items-center gap-4 py-4">
    <a class="shrink-0" href={localizePath('/', lang)} aria-label="HexaCybert home">
      <Logo />
    </a>

    <nav class="ml-4 hidden items-center gap-1 xl:flex" aria-label="Primary">
      {primary.map((key) => (
        <a class="rounded px-3 py-2 text-sm font-bold hc-muted hover:bg-white/5 hover:text-[var(--hc-accent)]" href={localizePath(`/${key}`, lang)}>{labelFor(key)}</a>
      ))}
      <div class="group relative">
        <button class="rounded px-3 py-2 text-sm font-bold hc-muted hover:bg-white/5 hover:text-[var(--hc-accent)]" type="button">{t.more}</button>
        <div class="invisible absolute left-0 top-full z-50 mt-2 w-[38rem] opacity-0 transition group-hover:visible group-hover:opacity-100">
          <div class="hc-card grid grid-cols-2 gap-3 p-4">
            {secondary.map((key) => {
              const section = getSection(lang, key as never);
              return (
                <a class="rounded p-3 hover:bg-white/5" href={localizePath(`/${key}`, lang)}>
                  <div class="flex items-center gap-2 font-black text-[var(--hc-text)]"><Icon name={section.icon} class="h-5 w-5 text-[var(--hc-accent)]" />{section.title}</div>
                  <p class="mt-2 text-sm hc-muted">{section.description}</p>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </nav>

    <form class="relative ml-auto hidden w-full max-w-sm lg:block" action={localizePath('/search', lang)}>
      <Icon name="tabler:search" class="pointer-events-none absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 hc-muted" />
      <input class="hc-input pl-10" type="search" name="q" placeholder={t.searchPlaceholder} />
    </form>

    <select class="hidden rounded border px-3 py-2 text-sm font-bold md:block" style="border-color: var(--hc-border); background: var(--hc-card); color: var(--hc-text)" aria-label={t.langLabel} data-language-select>
      {Object.entries(languages).map(([code, label]) => (
        <option value={alternateLangPath(currentPath, code as Lang)} selected={code === lang}>{label}</option>
      ))}
    </select>

    <button class="rounded border p-2 text-[var(--hc-text)] xl:hidden" style="border-color: var(--hc-border)" type="button" aria-expanded="false" aria-controls="mobile-nav" data-menu-toggle>
      <Icon name="tabler:menu-2" class="h-6 w-6" />
    </button>
  </div>

  <nav id="mobile-nav" class="hidden border-t xl:hidden" style="border-color: var(--hc-border)" data-menu>
    <div class="hc-shell grid gap-4 py-4 md:grid-cols-2">
      <div>
        <p class="hc-eyebrow">{t.explore}</p>
        <div class="mt-3 grid gap-1">
          {[...primary, ...secondary].map((key) => (
            <a class="rounded px-3 py-2 font-bold hc-muted hover:bg-white/5 hover:text-[var(--hc-accent)]" href={localizePath(`/${key}`, lang)}>{labelFor(key)}</a>
          ))}
        </div>
      </div>
      <form class="relative" action={localizePath('/search', lang)}>
        <p class="hc-eyebrow mb-3">{t.search}</p>
        <Icon name="tabler:search" class="pointer-events-none absolute left-3 top-[3.15rem] h-5 w-5 hc-muted" />
        <input class="hc-input pl-10" type="search" name="q" placeholder={t.searchPlaceholder} />
      </form>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const toggle = target.closest('[data-menu-toggle]');
    if (!toggle) return;
    const menu = document.querySelector('[data-menu]');
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden', expanded);
  });

  document.addEventListener('change', (event) => {
    const target = event.target;
    if (target instanceof HTMLSelectElement && target.matches('[data-language-select]')) {
      window.location.href = target.value;
    }
  });
</script>
