---
import { Icon } from 'astro-icon/components';
import type { Article } from '~/data/hexacyber';
import { getSection } from '~/data/hexacyber';
import type { Lang } from '~/utils/i18n';
import { localizePath } from '~/utils/i18n';

interface Props {
  article: Article;
  lang: Lang;
}

const { article, lang } = Astro.props;
const section = getSection(lang, article.category);
---

<article class="hc-card p-5 transition hover:-translate-y-0.5 hover:border-[var(--hc-accent)]">
  <div class="mb-4 flex flex-wrap items-center gap-2 text-xs font-extrabold uppercase tracking-wide text-[var(--hc-accent)]">
    <Icon name={section.icon} class="h-4 w-4" />
    <span>{section.title}</span>
    <span class="hc-muted">/</span>
    <span>{article.level}</span>
  </div>
  <h3 class="text-xl font-black">
    <a href={localizePath(`/articles/${article.slug}`, lang)}>{article.title}</a>
  </h3>
  <p class="mt-3 text-base leading-7 hc-muted">{article.description}</p>
  <div class="mt-5 flex flex-wrap gap-2 text-xs font-bold hc-muted">
    <time datetime={article.date}>{article.date}</time>
    <span>{article.readingTime}</span>
    <span>{article.author}</span>
  </div>
</article>
