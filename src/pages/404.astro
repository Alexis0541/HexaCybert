---
import PageLayout from '~/layouts/PageLayout.astro';
---

<PageLayout metadata={{ title: 'Page not found', description: 'The requested HexaCyber page could not be found.' }} lang="en">
  <section class="hc-shell py-24 text-center">
    <p class="hc-eyebrow">404</p>
    <h1 class="mt-3 text-5xl font-black">Page not found</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg hc-muted">The page may have moved, or the address may be incomplete.</p>
    <a class="hc-button mt-8" href="/en/">Return home</a>
  </section>
</PageLayout>
