---
import { Icon } from 'astro-icon/components';
import PageLayout from '~/layouts/PageLayout.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import SecurityTools from '~/components/SecurityTools.astro';
import { adminCountry, contactEmail, contactMailto, getArticles, getResourceGroups, getSection, legalPages, sectionOrder, type SectionKey } from '~/data/hexacybert';
import { langCodes, localizePath, ui, type Lang } from '~/utils/i18n';

export const getStaticPaths = () =>
  langCodes.flatMap((lang) =>
    [...sectionOrder, 'about', 'a-propos', 'contact', 'search', ...Object.keys(legalPages)].map((slug) => ({ params: { lang, slug } }))
  );

const lang = Astro.params.lang as Lang;
const t = ui[lang];
const slug = String(Astro.params.slug);
const articles = getArticles(lang);
const isSection = sectionOrder.includes(slug as SectionKey);
const section = isSection ? getSection(lang, slug as SectionKey) : undefined;
const legal = legalPages[slug as keyof typeof legalPages];
const legalLang = (['en', 'fr', 'es'].includes(lang) ? lang : 'en') as 'en' | 'fr' | 'es';
const localizedLegalTitle = legal?.title[legalLang];
const isAbout = slug === 'about' || slug === 'a-propos';
const title = section?.title ?? localizedLegalTitle ?? (isAbout ? t.aboutTitle : slug === 'contact' ? t.contactTitle : t.searchTitle);
const description =
  section?.description ??
  legal?.description[legalLang] ??
  (isAbout
    ? t.aboutDescription
    : slug === 'contact'
      ? t.contactDescription
      : t.searchDescription);
const filtered = isSection
  ? slug === 'privacy-center'
    ? articles.filter((article) => article.category === 'privacy')
    : slug === 'resources'
      ? articles
      : articles.filter((article) => article.category === slug)
  : articles;
const levels = ['Beginner', 'Intermediate', 'Advanced'] as const;
const searchItems = articles.map((article) => ({ ...article, url: localizePath(`/articles/${article.slug}`, lang) }));
const resourceGroups = getResourceGroups(lang);
const aboutBlocks = {
  en: [
    'HexaCybert publishes practical cybersecurity, privacy, VPN, antivirus, password manager and device security guidance for everyday readers.',
    'The site is administered from France and is built around cautious editorial rules: no invented tests, no fake awards, no unsupported anonymity promises and no hidden affiliate pressure.',
    'When we compare tools, we explain trade-offs such as trust model, recovery, compatibility, cost, usability and privacy limits. Security advice is written as a baseline that readers can adapt to their own risk level.',
  ],
  fr: [
    'HexaCybert est un projet éditorial indépendant administré depuis la France. Le site publie des guides pratiques sur la cybersécurité, la confidentialité, les VPN, les antivirus, les gestionnaires de mots de passe et la protection des appareils.',
    'La ligne éditoriale est volontairement prudente : pas de tests inventés, pas de faux prix, pas de promesses d’anonymat non vérifiées et pas de pression affiliée cachée.',
    'Dans les comparatifs, nous expliquons les compromis : modèle de confiance, récupération, compatibilité, coût, facilité d’usage, limites de confidentialité et conditions qui peuvent changer.',
    'Pour toute correction, question éditoriale ou demande de confidentialité, le contact public est hexacybertprivate@gmail.com.',
  ],
  es: [
    'HexaCybert publica guias practicas sobre ciberseguridad, privacidad, VPN, antivirus, gestores de contrasenas y proteccion de dispositivos.',
    'El sitio se administra desde Francia y sigue reglas editoriales prudentes: sin pruebas inventadas, sin premios falsos, sin promesas de anonimato sin respaldo y sin presion de afiliados oculta.',
    'En las comparativas explicamos ventajas y limites: modelo de confianza, recuperacion, compatibilidad, coste, facilidad de uso y limites de privacidad.',
  ],
} as const;
const contactBlocks = {
  en: ['For editorial questions, corrections, privacy requests or security resource suggestions, contact HexaCybert by email.', `Administration country: ${adminCountry.en}.`],
  fr: ['Pour les questions éditoriales, corrections, demandes de confidentialité ou suggestions de ressources, contactez HexaCybert par e-mail.', `Pays d’administration : ${adminCountry.fr}.`, 'HexaCybert ne publie pas d’adresse postale, de numéro fiscal ou de relation commerciale qui ne serait pas vérifiable publiquement.'],
  es: ['Para preguntas editoriales, correcciones, solicitudes de privacidad o sugerencias de recursos de seguridad, contacta con HexaCybert por correo.', `Pais de administracion: ${adminCountry.es}.`],
} as const;
---

<PageLayout metadata={{ title, description }} lang={lang}>
  <section class="border-b" style="border-color: var(--hc-border)">
    <div class="hc-shell py-12">
      <nav class="mb-5 text-base hc-muted" aria-label="Breadcrumb">
        <a class="hc-link" href={localizePath('/', lang)}>{t.home}</a>
        <span> / </span>
        <span>{title}</span>
      </nav>
      {section && <Icon name={section.icon} class="mb-5 h-10 w-10 text-[var(--hc-accent)]" />}
      <h1 class="text-4xl font-black sm:text-6xl">{title}</h1>
      <p class="mt-5 max-w-3xl text-xl leading-9 hc-muted">{description}</p>
    </div>
  </section>

  {isSection && slug !== 'tools' && slug !== 'privacy-center' && slug !== 'resources' && (
    <section class="hc-shell py-6">
      <div class="flex flex-wrap gap-2">
        <button class="hc-button hc-button-secondary" type="button" data-filter="all">{t.all}</button>
        {levels.map((level) => <button class="hc-button hc-button-secondary" type="button" data-filter={level}>{t.levels[level]}</button>)}
      </div>
    </section>
  )}

  {isSection && slug === 'tools' && (
    <section class="hc-shell hc-section">
      <SecurityTools lang={lang} />
    </section>
  )}

  {isSection && slug === 'privacy-center' && (
    <section class="hc-shell hc-section">
      <div class="grid gap-5 lg:grid-cols-3">
        {levels.map((level) => (
          <div class="hc-card p-5">
            <h2 class="text-2xl font-black">{t.levels[level]}</h2>
            <div class="mt-5 grid gap-4">
              {articles.filter((article) => article.category === 'privacy' && article.level === level).map((article) => <ArticleCard article={article} lang={lang} />)}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {isSection && slug === 'resources' && (
    <section class="hc-shell hc-section">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {resourceGroups.map(([group, links]) => (
          <div class="hc-card p-5">
            <h2 class="text-2xl font-black">{group}</h2>
            <ul class="mt-4 space-y-3 hc-muted">
              {links.map((articleSlug) => {
                const article = articles.find((item) => item.slug === articleSlug);
                return article ? <li><a class="hover:text-[var(--hc-accent)]" href={localizePath(`/articles/${article.slug}`, lang)}>{article.title}</a></li> : null;
              })}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  {isSection && !['tools', 'privacy-center', 'resources'].includes(slug) && (
    <section class="hc-shell hc-section">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-filter-list>
        {filtered.map((article) => <div data-level={article.level}><ArticleCard article={article} lang={lang} /></div>)}
      </div>
    </section>
    <script>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const filter = target.closest('[data-filter]')?.getAttribute('data-filter');
        if (!filter) return;
        document.querySelectorAll('[data-filter-list] [data-level]').forEach((item) => {
          item.classList.toggle('hidden', filter !== 'all' && item.getAttribute('data-level') !== filter);
        });
      });
    </script>
  )}

  {slug === 'search' && (
    <section class="hc-shell hc-section">
      <input class="hc-input" type="search" placeholder={t.searchPlaceholderShort} data-site-search />
      <div class="mt-6 grid gap-4 md:grid-cols-2" data-search-results>
        {articles.slice(0, 24).map((article) => <ArticleCard article={article} lang={lang} />)}
      </div>
    </section>
    <script define:vars={{ articles: searchItems }}>
      const input = document.querySelector('[data-site-search]');
      const results = document.querySelector('[data-search-results]');
      input?.addEventListener('input', () => {
        const query = input.value.toLowerCase();
        const matches = articles.filter((item) => `${item.title} ${item.description} ${item.category} ${item.tags.join(' ')}`.toLowerCase().includes(query));
        if (results) {
          results.innerHTML = matches
            .slice(0, 50)
            .map((item) => `<article class="hc-card p-5"><h2 class="text-xl font-black"><a href="${item.url}">${item.title}</a></h2><p class="mt-2 hc-muted">${item.description}</p></article>`)
            .join('');
        }
      });
    </script>
  )}

  {isAbout && (
    <section class="hc-shell hc-section">
      <div class="hc-prose max-w-4xl">
        {aboutBlocks[legalLang].map((paragraph) => <p>{paragraph}</p>)}
        <p><a href={localizePath('/methodology', lang)}>{legalPages.methodology.title[legalLang]}</a> · <a href={localizePath('/editorial-policy', lang)}>{legalPages['editorial-policy'].title[legalLang]}</a> · <a href={localizePath('/corrections-policy', lang)}>{legalPages['corrections-policy'].title[legalLang]}</a></p>
      </div>
    </section>
  )}

  {slug === 'contact' && (
    <section class="hc-shell hc-section">
      <div class="hc-card max-w-3xl p-6">
        <div class="hc-prose">
          {contactBlocks[legalLang].map((paragraph) => <p>{paragraph}</p>)}
          <p><a href={contactMailto}>{contactEmail}</a></p>
        </div>
      </div>
    </section>
  )}

  {legal && (
    <section class="hc-shell hc-section">
      <div class="hc-prose max-w-4xl">
        {legal.body[legalLang].map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  )}
</PageLayout>
